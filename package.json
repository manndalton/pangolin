{
  "name": "pangolin",
  "version": "1.0.0",
  "description": "A self-hosted tunneled reverse proxy server with identity and access control",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:reset": "rm -f db/db.sqlite && drizzle-kit migrate"
  },
  "keywords": [
    "tunnel",
    "reverse-proxy",
    "self-hosted",
    "access-control",
    "identity"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "dependencies": {
    "@node-rs/argon2": "^2.0.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "http-proxy": "^1.18.1",
    "jose": "^5.6.3",
    "nodemailer": "^6.9.14",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/http-proxy": "^1.17.15",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.15",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.24.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
